# Signed admin session secret (32+ random characters)
SECRET_KEY=change-this-to-a-long-random-secret-key

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# TeamWicked AI API
AI_API_URL=https://api.teamwicked.me/v1
AI_MODEL=teamwicked-mimo
TEAMWICKED_API_KEY=replace-with-teamwicked-api-key

# Public site identity
SITE_NAME=Wickedhost Docs
SITE_URL=https://docs.teamwicked.me

# Optional. Defaults to ./instance/docs.db for compatibility with the former Flask app.
DOCS_DB_PATH=./instance/docs.db
